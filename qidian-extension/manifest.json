{
  "manifest_version": 3,
  "name": "Qidian Chapter Scraper",
  "version": "2.1",
  "description": "Lưu chương Qidian về máy: chụp ảnh (.jpg) hoặc copy văn bản (.txt)",
  "permissions": ["activeTab", "downloads", "storage", "debugger", "scripting"],
  "host_permissions": ["https://www.qidian.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Qidian Scraper"
  }
}
