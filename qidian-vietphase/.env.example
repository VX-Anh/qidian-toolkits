# ── Google Gemini (native SDK google-genai trên Vertex AI) ────────
# Auth (dev): Application Default Credentials
#   gcloud auth application-default login
#   gcloud config set project <PROJECT_ID>
# Auth (Docker/host): service-account JSON. Tải key từ GCP Console, đặt vào
#   ./secrets/gcp-sa.json (docker-compose mount sẵn read-only) và đặt
#   GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json (compose đã set hộ).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

GEMINI_MODEL=gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash

# Gemini 3 không tắt thinking được. LOW = nhanh/rẻ (hợp dịch). LOW|MEDIUM|HIGH|MINIMAL
THINKING_LEVEL=LOW
MAX_OUTPUT_TOKENS=16384

# Rate limit token-bucket nội bộ (hạ xuống nếu quota Vertex thấp)
LLM_RPM=500
LLM_TPM=150000

# ── Đường dẫn dữ liệu ─────────────────────────────────────────────────────
# Dev trên Windows: dùng đường dẫn C:\... như dưới.
# Khi deploy bằng Docker: KHÔNG cần set ở đây — docker-compose.yml đã override
# sang /data/... (volume bền vững). Các biến: INPUT_DIR, OUTPUT_DIR,
# OCR_IMAGES_DIR, VIETPHASE_DIR, DB_PATH.
INPUT_DIR=C:\Users\ASUS\Documents\work\qidian\data\input
OUTPUT_DIR=C:\Users\ASUS\Documents\work\qidian\data\output
RULES_DIR=rules

# Vị trí file SQLite (mặc định backend/db/state.db khi chạy dev).
# DB_PATH=backend/db/state.db

# Số TranslatorAgent chạy song song
CONCURRENCY=3

# ── OCR ───────────────────────────────────────────────────────────────────
# "paddle" = PaddleOCR offline (chỉ chạy được trên máy Windows có venv riêng).
# Trong Docker hãy dùng "gemini" (OCR qua Gemini vision).
# OCR_DEFAULT_ENGINE=paddle
