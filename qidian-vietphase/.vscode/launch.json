{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Debug (no reload)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--port", "9999"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      "name": "FastAPI: Run with reload (no breakpoints)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "backend.main:app",
        "--reload",
        "--reload-include", "*.html",
        "--reload-include", "*.css",
        "--reload-include", "*.js",
        "--port", "9999"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal"
    }
  ]
}
